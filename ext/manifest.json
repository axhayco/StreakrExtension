{
  "manifest_version": 3,
  "name": "Streakr",
  "version": "1.2.0",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://leetcode.com/*",
    "*://*.youtube.com/*",
    "*://*.reddit.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.instagram.com/*",
    "*://*.facebook.com/*",
    "*://*.netflix.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://leetcode.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "streakr_icon.jpg",
      "48": "streakr_icon.jpg",
      "128": "streakr_icon.jpg"
    }
  },
  "icons": {
    "16": "streakr_icon.jpg",
    "48": "streakr_icon.jpg",
    "128": "streakr_icon.jpg"
  }
}
